# --- CONFIGURAÇÃO DO BANCO DE DADOS ---
# Altere se necessário (XAMPP padrão: 127.0.0.1 porta 3306)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=biblioteca_vision
DB_USER=root
DB_PASS=

# --- CONFIGURAÇÃO DA I.A. ---
# Obtenha sua chave em: https://aistudio.google.com/
GEMINI_API_KEY=SUA_CHAVE_AQUI
GEMINI_MODEL=gemini-2.5-flash-lite

# --- CONFIGURAÇÕES DO SERVIDOR ---
# Deixe vazio para se adaptar a qualquer PC automaticamente
APP_URL=
